# Gemini API Key (Required for AI features)
GEMINI_API_KEY=

# SMS Gateway Configuration (Optional - for Real SMS notifications)
# Example: KavehNegar, Melipayamak, or generic API
SMS_API_KEY=
SMS_SENDER_NUMBER=
SMS_PROVIDER_URL=https://api.kavenegar.com/v1/%API_KEY%/sms/send.json

# SMTP Configuration for Cloud Email Backups (Optional)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=false

# Microsoft Entra ID (Azure AD) Client ID for OneDrive Backup (Optional)
VITE_MICROSOFT_CLIENT_ID=

